local function fps_universal_bypass()
    pcall(function()
        local mt = getrawmetatable(game)
        if mt then
            local old_namecall = mt.__namecall
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                local args = {...}

                if method == "HttpGet" or method == "HttpPost" then
                    return ""
                end

                if method == "GetObjects" and type(args[1]) == "string" then
                    if args[1]:find("anticheat") or args[1]:find("bypass") then
                        return {}
                    end
                end

                if old_namecall then
                    return old_namecall(self, ...)
                end
                return nil
            end)
        end
    end)

    pcall(function()
        local ac_names = {"anticheat", "AntiCheat", "AC", "guardian", "Guardian"}
        for _, name in pairs(ac_names) do
            if _G[name] then _G[name] = nil end
            rawset(_G, name, nil)
        end
    end)
end

fps_universal_bypass()

