-- FLY
local function stopFly()
    if not flying then return end
    flying = false
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    local currentChar = player.Character
    if currentChar and currentChar:FindFirstChildWhichIsA("Humanoid") then
        currentChar:FindFirstChildWhichIsA("Humanoid").PlatformStand = false
    end
    local root = currentChar and currentChar:FindFirstChild("HumanoidRootPart")
    if root then
        if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
        if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    end
end

local function startFly()
    if flying then stopFly() end
    if not flyEnabled then return end
    
    local currentChar = player.Character
    if not currentChar then
        player.CharacterAdded:Wait()
        currentChar = player.Character
    end
    local humanoid = currentChar:FindFirstChildWhichIsA("Humanoid")
    local root = currentChar:FindFirstChild("HumanoidRootPart")
    if not root or not humanoid then return end
    
    flying = true
    local CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    local lastControl = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    local speed = 0
    
    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyGyro.P = 9e4
    flyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    flyBodyGyro.Parent = root
    flyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    flyBodyVelocity.Parent = root
    humanoid.PlatformStand = true
    
    local flyInputDown = userInput.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.W then CONTROL.F = flySpeed
        elseif input.KeyCode == Enum.KeyCode.S then CONTROL.B = -flySpeed
        elseif input.KeyCode == Enum.KeyCode.A then CONTROL.L = -flySpeed
        elseif input.KeyCode == Enum.KeyCode.D then CONTROL.R = flySpeed
        elseif input.KeyCode == Enum.KeyCode.E then CONTROL.Q = flySpeed * 2
        elseif input.KeyCode == Enum.KeyCode.Q then CONTROL.E = -flySpeed * 2
        end
    end)
    
    local flyInputUp = userInput.InputEnded:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.W then CONTROL.F = 0
        elseif input.KeyCode == Enum.KeyCode.S then CONTROL.B = 0
        elseif input.KeyCode == Enum.KeyCode.A then CONTROL.L = 0
        elseif input.KeyCode == Enum.KeyCode.D then CONTROL.R = 0
        elseif input.KeyCode == Enum.KeyCode.E then CONTROL.Q = 0
        elseif input.KeyCode == Enum.KeyCode.Q then CONTROL.E = 0
        end
    end)
    
    flyConnection = RunService.Heartbeat:Connect(function()
        if not flying then return end
        local currentChar = player.Character
        if not currentChar or not currentChar.Parent then stopFly(); return end
        local humanoid = currentChar:FindFirstChildWhichIsA("Humanoid")
        local root = currentChar:FindFirstChild("HumanoidRootPart")
        if not root or not humanoid then return end
        local camera = workspace.CurrentCamera
        
        if CONTROL.L + CONTROL.R ~= 0 or CONTROL.F + CONTROL.B ~= 0 or CONTROL.Q + CONTROL.E ~= 0 then
            speed = 50
        elseif speed ~= 0 then
            speed = 0
        end
        
        if (CONTROL.L + CONTROL.R) ~= 0 or (CONTROL.F + CONTROL.B) ~= 0 or (CONTROL.Q + CONTROL.E) ~= 0 then
            flyBodyVelocity.Velocity = ((camera.CFrame.LookVector * (CONTROL.F + CONTROL.B)) + 
                          ((camera.CFrame * CFrame.new(CONTROL.L + CONTROL.R, (CONTROL.F + CONTROL.B + CONTROL.Q + CONTROL.E) * 0.2, 0).p) - camera.CFrame.p)) * speed
            lastControl = {F = CONTROL.F, B = CONTROL.B, L = CONTROL.L, R = CONTROL.R}
        elseif speed ~= 0 then
            flyBodyVelocity.Velocity = ((camera.CFrame.LookVector * (lastControl.F + lastControl.B)) + 
                          ((camera.CFrame * CFrame.new(lastControl.L + lastControl.R, (lastControl.F + lastControl.B + CONTROL.Q + CONTROL.E) * 0.2, 0).p) - camera.CFrame.p)) * speed        else
            flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
        flyBodyGyro.CFrame = camera.CFrame
    end)
    
    flyConnection.flyInputDown = flyInputDown
    flyConnection.flyInputUp = flyInputUp
end

local function toggleFly()
    if flyEnabled then startFly() else stopFly() end
end

