-- ========== RADAR ==========
local function NewCircle(transparency, color, radius, filled, thickness)
    local circle = Drawing.new("Circle")
    circle.Transparency = transparency
    circle.Color = color
    circle.Visible = false
    circle.Thickness = thickness
    circle.Position = Vector2.new(0, 0)
    circle.Radius = radius
    circle.NumSides = math.clamp(radius * 55 / 100, 10, 75)
    circle.Filled = filled
    return circle
end

local function GetRelativePosition(pos, character)
    if not character or not character.PrimaryPart then return 0, 0 end
    local rootPart = character.PrimaryPart
    local cameraPos = Vector3.new(Camera.CFrame.Position.X, rootPart.Position.Y, Camera.CFrame.Position.Z)
    local relativeCF = CFrame.new(rootPart.Position, cameraPos)
    local relativePos = relativeCF:PointToObjectSpace(pos)
    return relativePos.X, relativePos.Z
end

local function CreateRadar()
    if radarObjects.background then radarObjects.background:Remove() end
    if radarObjects.border then radarObjects.border:Remove() end
    
    radarObjects.background = NewCircle(0.9, radarInfo.RadarBack, radarInfo.Radius, true, 1)
    radarObjects.background.Visible = true
    radarObjects.background.Position = radarInfo.Position
    
    radarObjects.border = NewCircle(0.75, radarInfo.RadarBorder, radarInfo.Radius, false, 3)
    radarObjects.border.Visible = true
    radarObjects.border.Position = radarInfo.Position
end

local function UpdateRadarDots()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player then
            if not radarObjects.dots[player] then
                local dot = NewCircle(1, radarInfo.PlayerDot, 3, true, 1)
                radarObjects.dots[player] = dot
            end
        end
    end
end

local function UpdateRadar()
    if not radarEnabled then return end
    
    local character = player.Character
    if not character or not character.PrimaryPart then return end
    
    for player, dot in pairs(radarObjects.dots) do
        if player and player.Character and player.Character.PrimaryPart then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local relX, relZ = GetRelativePosition(player.Character.PrimaryPart.Position, character)
                local newPos = radarInfo.Position - Vector2.new(relX * radarInfo.Scale, relZ * radarInfo.Scale)
                
                if (newPos - radarInfo.Position).magnitude < radarInfo.Radius - 2 then
                    dot.Radius = 3
                    dot.Position = newPos
                    dot.Visible = true
                else
                    local dist = (radarInfo.Position - newPos).magnitude
                    local calc = (radarInfo.Position - newPos).unit * (dist - radarInfo.Radius)
                    local inside = Vector2.new(newPos.X + calc.X, newPos.Y + calc.Y)
                    dot.Radius = 2
                    dot.Position = inside
                    dot.Visible = true
                end
                
                if radarInfo.TeamCheck then
                    if player.Team == Player.Team then
                        dot.Color = radarInfo.Team
                    else
                        dot.Color = radarInfo.Enemy
                    end
                else
                    dot.Color = radarInfo.PlayerDot
                end
                
                if radarInfo.HealthColor and humanoid then
                    local healthPercent = humanoid.Health / humanoid.MaxHealth
                    dot.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
                end
            else
                dot.Visible = false
            end
        else
            dot.Visible = false
        end
    end
end

local function SetupRadar()
    radarObjects = {
        background = nil,
        border = nil,
        dots = {},
        localDot = nil
    }
    
    CreateRadar()
    
    radarObjects.localDot = Drawing.new("Triangle")
    radarObjects.localDot.Visible = true
    radarObjects.localDot.Thickness = 1
    radarObjects.localDot.Filled = true
    radarObjects.localDot.Color = radarInfo.LocalPlayerDot
    radarObjects.localDot.PointA = radarInfo.Position + Vector2.new(0, -6)
    radarObjects.localDot.PointB = radarInfo.Position + Vector2.new(-3, 6)
    radarObjects.localDot.PointC = radarInfo.Position + Vector2.new(3, 6)
    
    UpdateRadarDots()
end

local function EnableRadar()
    if radarEnabled then return end
    radarEnabled = true
    SetupRadar()
    
    task.spawn(function()
        while radarEnabled do
            UpdateRadar()
            task.wait()
        end
    end)
end

local function DisableRadar()
