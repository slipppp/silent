-- POTATO MODE
local function setPotatoMode(state)
    if state then
        originalLighting.Brightness = Lighting.Brightness
        originalLighting.Ambient = Lighting.Ambient
        originalLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        originalLighting.GlobalShadows = Lighting.GlobalShadows
        originalLighting.FogEnd = Lighting.FogEnd
        originalLighting.FogStart = Lighting.FogStart
        
        Lighting.Brightness = 2
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.FogStart = 0
        
        for _, decal in pairs(workspace:GetDescendants()) do
            if decal:IsA("Decal") or decal:IsA("Texture") then
                table.insert(originalDecals, decal)
                decal.Transparency = 1
            end
        end
        
        for _, particle in pairs(workspace:GetDescendants()) do
            if particle:IsA("ParticleEmitter") or particle:IsA("Fire") or particle:IsA("Smoke") or particle:IsA("Sparkles") then
                particle.Enabled = false
            end
        end
        
        Library:Notify("Potato Mode enabled - FPS Boost", "success")
    else
        Lighting.Brightness = originalLighting.Brightness
        Lighting.Ambient = originalLighting.Ambient
        Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
        Lighting.GlobalShadows = originalLighting.GlobalShadows
        Lighting.FogEnd = originalLighting.FogEnd
        Lighting.FogStart = originalLighting.FogStart
        
        for _, decal in pairs(originalDecals) do
            if decal and decal.Parent then
                decal.Transparency = 0
            end
        end
        originalDecals = {}
        
        Library:Notify("Potato Mode disabled", "warning")
    end
end

-- ANTI AIM
local function GetClosestEnemyForAntiAim()
    local closest = nil
    local shortest = 500
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(game:GetService("Players"):GetPlayers()) do
        if player ~= Player and player.Character then
            local part = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (center - Vector2.new(pos.X, pos.Y)).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

local function ApplyAntiAim()
    if not antiAimEnabled then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoidRoot = character:FindFirstChild("HumanoidRootPart")
    if humanoidRoot then
        if antiAimMode == "Spin" then
            local angle = (antiAimSpeed or 360) * tick() % 360
            humanoidRoot.CFrame = CFrame.new(humanoidRoot.Position) * CFrame.Angles(0, math.rad(angle), 0)
        elseif antiAimMode == "Backwards" then
            humanoidRoot.CFrame = humanoidRoot.CFrame * CFrame.Angles(0, math.rad(180), 0)
        elseif antiAimMode == "Jitter" then
            local jitter = math.sin(tick() * 20) * 45
            humanoidRoot.CFrame = humanoidRoot.CFrame * CFrame.Angles(0, math.rad(jitter), 0)
        elseif antiAimMode == "UpsideDown" then
            humanoidRoot.CFrame = humanoidRoot.CFrame * CFrame.Angles(math.rad(180), 0, 0)
        elseif antiAimMode == "Fake" then
            local target = GetClosestEnemyForAntiAim()
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = target.Character.HumanoidRootPart.Position
                local direction = (targetPos - humanoidRoot.Position).unit
                local targetAngle = math.atan2(direction.X, direction.Z)
                humanoidRoot.CFrame = CFrame.new(humanoidRoot.Position) * CFrame.Angles(0, targetAngle + math.rad(180), 0)
            end
        end
    end
end

-- ========== PLAYER FUNCTIONS ==========
local function viewPlayer(player)
    if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local originalCameraType = Camera.CameraType
        Camera.CameraType = Enum.CameraType.Scriptable
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if hrp and hrp.Parent then
                Camera.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 2, 5), hrp.Position)
            else
                connection:Disconnect()
                Camera.CameraType = originalCameraType
            end
        end)
        task.delay(5, function()
            if connection then connection:Disconnect() end
            Camera.CameraType = originalCameraType
        end)
    end
end

local function gotoPlayer(player)
    if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = hrp.CFrame + Vector3.new(0, 3, 0)
        end
    end
end

local function pullPlayer(player)
    if pullingPlayer then return end
    pullingPlayer = true
    
    if pullConnection then pullConnection:Disconnect() end
    
    pullConnection = RunService.RenderStepped:Connect(function()
        if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local localHrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            local targetHrp = player.Character.HumanoidRootPart
            if localHrp and targetHrp then
                targetHrp.CFrame = localHrp.CFrame + Vector3.new(0, 3, 0)
            end
        else
            pullConnection:Disconnect()
            pullingPlayer = false
        end
    end)
    
    task.delay(10, function()
        if pullConnection then pullConnection:Disconnect() end
        pullingPlayer = false
    end)
end

local function bringPlayer(player)
    if bringingPlayer then return end
    bringingPlayer = true
    
    if bringConnection then bringConnection:Disconnect() end
    
    bringConnection = RunService.RenderStepped:Connect(function()
        if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local localHrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if localHrp then
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = localHrp.CFrame + Vector3.new(0, 3, 2)
                end
            end
        else
            bringConnection:Disconnect()
            bringingPlayer = false
        end
    end)
    
    task.delay(10, function()
        if bringConnection then bringConnection:Disconnect() end
        bringingPlayer = false
    end)
end

