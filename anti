-- ========== FUNÇÕES AIMBOT ==========
local function getAimbotPart(character)
    if not character then return nil end
    local parts = {
        Head = character:FindFirstChild("Head"),
        Torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"),
        HumanoidRootPart = character:FindFirstChild("HumanoidRootPart"),
        LeftArm = character:FindFirstChild("LeftArm") or character:FindFirstChild("LeftUpperArm"),
        RightArm = character:FindFirstChild("RightArm") or character:FindFirstChild("RightUpperArm"),
        LeftLeg = character:FindFirstChild("LeftLeg") or character:FindFirstChild("LeftUpperLeg"),
        RightLeg = character:FindFirstChild("RightLeg") or character:FindFirstChild("RightUpperLeg")
    }
    return parts[aimbotPart]
end

local function canSeeAimbotTarget(origin, target)
    if not aimbotWallCheck then return true end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character}

    local direction = (target - origin).unit * (origin - target).magnitude
    local result = workspace:Raycast(origin, direction, params)

    if result then
        local hit = result.Instance
        if hit and hit.Parent and hit.Parent:FindFirstChild("Humanoid") then
            return true
        end
        if hit and hit.Parent and hit.Parent.Parent and hit.Parent.Parent:FindFirstChild("Humanoid") then
            return true
        end
        return false
    end
    return true
end

local function getPredictedPosition(character, part, predictionTime)
    if predictionTime <= 0 then return part.Position end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if humanoid and rootPart then
        local velocity = rootPart.AssemblyLinearVelocity
        if velocity.Magnitude > 3 then
            return part.Position + (velocity * predictionTime)
        end
    end
    return part.Position
end

local function updateAimbotFOVCircle()
    if aimbotFovCircle then aimbotFovCircle:Remove(); aimbotFovCircle = nil end
    if aimbotCenterDot then aimbotCenterDot:Remove(); aimbotCenterDot = nil end
    
    if aimbotEnabled and aimbotShowFOV then
        local camera = workspace.CurrentCamera
        local viewportSize = camera.ViewportSize
        aimbotFovCircle = Drawing.new("Circle")
        aimbotFovCircle.Visible = true
        aimbotFovCircle.Radius = aimbotFOV
        aimbotFovCircle.Color = aimbotFovColor
        aimbotFovCircle.Thickness = 2
        aimbotFovCircle.Filled = false
        aimbotFovCircle.NumSides = 64
        aimbotFovCircle.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
        aimbotFovCircle.Transparency = 0.5
    end
    
    if aimbotEnabled and aimbotShowDot then
        local camera = workspace.CurrentCamera
        local viewportSize = camera.ViewportSize
        aimbotCenterDot = Drawing.new("Circle")
        aimbotCenterDot.Visible = true
        aimbotCenterDot.Radius = 3
        aimbotCenterDot.Color = aimbotFovColor
        aimbotCenterDot.Filled = true
        aimbotCenterDot.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    end
end

local function onAimbot()
    if not aimbotEnabled then return end
    local camera = workspace.CurrentCamera
    if not player.Character or not player.Character:FindFirstChild("Humanoid") or player.Character.Humanoid.Health <= 0 then
        return
    end
    
    local closestPlayer = nil
    local closestDistance = math.huge
    local targetPartObj = nil
    local screenCenter = camera.ViewportSize / 2
    
    for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Humanoid") and otherPlayer.Character.Humanoid.Health > 0 then
            if aimbotTeamCheck and player.Team and otherPlayer.Team and player.Team == otherPlayer.Team then 
                -- skip
            else
                local part = getAimbotPart(otherPlayer.Character)
                if part then
                    local predictedPos = getPredictedPosition(otherPlayer.Character, part, aimbotPrediction)
                    local partPosition, onScreen = camera:WorldToScreenPoint(predictedPos)
                    
                    if onScreen then
                        local targetPos = Vector2.new(partPosition.X, partPosition.Y)
                        local distanceToCenter = (screenCenter - targetPos).magnitude
                        if distanceToCenter <= aimbotFOV then
                            local canSee = canSeeAimbotTarget(camera.CFrame.Position, predictedPos)
                            if canSee and distanceToCenter < closestDistance then
                                closestDistance = distanceToCenter
                                closestPlayer = otherPlayer
                                targetPartObj = part
                            end
                        end
                    end
                end
            end
        end
    end
    
    if closestPlayer and targetPartObj then
        local predictedPos = getPredictedPosition(closestPlayer.Character, targetPartObj, aimbotPrediction)
        local targetDirection = (predictedPos - camera.CFrame.Position).unit
        
        if aimbotSmoothness > 0 and aimbotSmoothness < 10 then
            local currentCFrame = camera.CFrame
            local newCFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + targetDirection)
            local lerpFactor = math.clamp(1 / (aimbotSmoothness + 5), 0.1, 0.5)
            camera.CFrame = currentCFrame:Lerp(newCFrame, lerpFactor)
        else
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + targetDirection)
        end
    end
end

