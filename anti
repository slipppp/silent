local function setInvisibleFromSkin(state)
    local character = player.Character
    if not character then return end
    
    if state then
        originalTransparencies = {}
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "TorsoMesh" then
                originalTransparencies[part] = part.Transparency
                part.Transparency = 1
            end
        end
    else
        for part, transparency in pairs(originalTransparencies) do
            if part and part.Parent then
                part.Transparency = transparency
            end
        end
        originalTransparencies = {}
    end
end

-- ========== RICE HAT FUNÇÕES ==========
local function GetMaterialEnum(matName)
    local materials = {
        ["Plastic"] = Enum.Material.Plastic,
        ["Neon"] = Enum.Material.Neon,
        ["Glass"] = Enum.Material.Glass,
        ["SmoothPlastic"] = Enum.Material.SmoothPlastic,
        ["Metal"] = Enum.Material.Metal,
        ["Wood"] = Enum.Material.Wood,
        ["Fabric"] = Enum.Material.Fabric,
        ["Granite"] = Enum.Material.Granite,
        ["Marble"] = Enum.Material.Marble,
        ["Concrete"] = Enum.Material.Concrete,
        ["Brick"] = Enum.Material.Brick,
        ["ForceField"] = Enum.Material.ForceField,
    }
    return materials[matName] or Enum.Material.ForceField
end

local function createRiceHat()
    if riceHatItem then 
        riceHatItem:Destroy()
        riceHatItem = nil
    end
    
    if not riceHatEnabled then return end
    
    local character = player.Character
    if not character then return end
    
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    local hat = Instance.new("Part")
    hat.Name = "RiceHat"
    hat.Size = Vector3.new(3, 0.3, 3)
    hat.Shape = Enum.PartType.Cylinder
    hat.CanCollide = false
    hat.Anchored = false
    hat.Material = GetMaterialEnum(riceHatMaterial)
