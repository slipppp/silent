-- ========== FUNÇÕES SILENT AIM ==========
local function getSilentAimPart(character)
    if not character then return nil end
    local parts = {
        character:FindFirstChild("Head"),
        character:FindFirstChild("UpperTorso"),
        character:FindFirstChild("Torso"),
        character:FindFirstChild("HumanoidRootPart"),
        character:FindFirstChild("LeftArm") or character:FindFirstChild("LeftUpperArm"),
        character:FindFirstChild("RightArm") or character:FindFirstChild("RightUpperArm"),
        character:FindFirstChild("LeftLeg") or character:FindFirstChild("LeftUpperLeg"),
        character:FindFirstChild("RightLeg") or character:FindFirstChild("RightUpperLeg")
    }
    for _, part in pairs(parts) do
        if part then return part end
    end
    return nil
end

local function canSeeSilentAimTarget(origin, target)
    if not silentAimWallCheck then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character}
    local direction = (target - origin).unit * (origin - target).magnitude
    local result = workspace:Raycast(origin, direction, params)
    if result then
        local hit = result.Instance
        if hit and hit.Parent then
            if hit.Parent:FindFirstChild("Humanoid") then return true end
            if hit.Parent.Parent and hit.Parent.Parent:FindFirstChild("Humanoid") then return true end
        end
        return false
    end
    return true
end

local function getPredictedSilentPosition(character, part, predictionTime)
    if predictionTime <= 0 then return part.Position end
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if humanoid and rootPart then
        local velocity = rootPart.AssemblyLinearVelocity
        if velocity.Magnitude > 3 then
            return part.Position + (velocity * predictionTime)
        end
    end
    return part.Position
end

local function updateSilentAimFovCircle()
    if silentAimFovCircle then silentAimFovCircle:Remove(); silentAimFovCircle = nil end
    if silentAimEnabled and silentAimShowFov then
        local camera = workspace.CurrentCamera
        if not camera then return end
        local viewportSize = camera.ViewportSize
        silentAimFovCircle = Drawing.new("Circle")
        silentAimFovCircle.Visible = true
        silentAimFovCircle.Radius = silentAimFov
        silentAimFovCircle.Color = silentAimFovColor
        silentAimFovCircle.Thickness = 2
        silentAimFovCircle.Filled = false
        silentAimFovCircle.NumSides = 64
        silentAimFovCircle.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
        silentAimFovCircle.Transparency = 0.5
    end
end

local function getSilentAimTarget()
    local camera = workspace.CurrentCamera
    if not camera then return nil, nil end
    local screenCenter = camera.ViewportSize / 2
    local closestPlayer = nil
    local closestDistance = math.huge
    local targetPartObj = nil
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("Humanoid") and otherPlayer.Character.Humanoid.Health > 0 then
            if silentAimTeamCheck and player.Team and otherPlayer.Team and player.Team == otherPlayer.Team then
                -- skip
            else
                local part = getSilentAimPart(otherPlayer.Character)
                if part then
                    local predictedPos = getPredictedSilentPosition(otherPlayer.Character, part, silentAimPrediction)
                    local partPosition, onScreen = camera:WorldToScreenPoint(predictedPos)
                    if onScreen then
                        local targetPos = Vector2.new(partPosition.X, partPosition.Y)
                        local distanceToCenter = (screenCenter - targetPos).magnitude
                        if distanceToCenter <= silentAimFov then
                            local canSee = canSeeSilentAimTarget(camera.CFrame.Position, predictedPos)
                            if canSee and distanceToCenter < closestDistance then
                                closestDistance = distanceToCenter
                                closestPlayer = otherPlayer
                                targetPartObj = part
                            end
                        end
                    end
                end
            end
        end
    end
    return closestPlayer, targetPartObj
end

-- ========== AUTO SHOOT FUNÇÕES ==========
local function getCurrentWeapon()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:GetAttribute("ToolType") == "Gun" then
            return tool
        end
    end
    return nil
end

local function performAutoShoot()
    if not autoShootEnabled or not silentAimEnabled then return end
    local now = os.clock()
    if now - lastAutoShootTime < autoShootDelay then return end
    
    local weapon = getCurrentWeapon()
    if not weapon then return end
    
    local target, targetPart = getSilentAimTarget()
    if not target or not targetPart then return end
    
    lastAutoShootTime = now
    
    local origin = player.Character and player.Character:FindFirstChild("Head")
    if not origin then return end
    
    local shouldHit = math.random(1, 100) <= silentAimHitChance
    local aimPos = shouldHit and targetPart.Position or (targetPart.Position + Vector3.new(
        math.random(-5, 5),
        math.random(-5, 5),
        math.random(-5, 5)
    ))
    
    -- Criar trail de bala
    local trail = Instance.new("Part")
    trail.Name = "BulletTrail"
    trail.Anchored = true
    trail.CanCollide = false
    trail.CanQuery = false
    trail.CanTouch = false
    trail.Material = Enum.Material.Neon
    trail.BrickColor = BrickColor.Yellow()
    local distance = (aimPos - origin.Position).magnitude
    trail.Size = Vector3.new(0.1, 0.1, distance)
    trail.CFrame = CFrame.new(origin.Position, aimPos) * CFrame.new(0, 0, -distance / 2)
    trail.Transparency = 0.5
    trail.Parent = workspace
    Debris:AddItem(trail, 0.1)
    
    -- Tentar disparar o evento de tiro
    local ShootEvent = ReplicatedStorage:FindFirstChild("GunRemotes") and ReplicatedStorage.GunRemotes:FindFirstChild("ShootEvent")
    if ShootEvent then
        local shots = {{origin.Position, aimPos, shouldHit and targetPart or nil}}
        ShootEvent:FireServer(shots)
    end
    
    -- Também tentar clicar
    pcall(function()
        local center = Camera.ViewportSize / 2
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 0)
        task.wait(0.01)
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 0)
    end)
end

local function startAutoShoot()
    if autoShootConnection then 
        autoShootConnection:Disconnect() 
        autoShootConnection = nil 
    end
    if autoShootEnabled and silentAimEnabled then
        autoShootConnection = RunService.Heartbeat:Connect(performAutoShoot)
    end
end

